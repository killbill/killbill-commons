<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                            https://raw.githubusercontent.com/spotbugs/spotbugs/4.6.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
      SpotBugs models Object.equals(Object)'s parameter as CheckForNull. These
      implementations use jakarta.annotation.Nullable to document the same
      null-accepted equals contract, which SpotBugs reports as a tightened
      override annotation.
    -->
    <Match>
        <Class name="org.killbill.commons.eventbus.Subscriber" />
        <Method name="equals" />
        <Bug pattern="NP_METHOD_PARAMETER_TIGHTENS_ANNOTATION" />
    </Match>

    <Match>
        <Class name="org.killbill.commons.eventbus.SubscriberRegistry$MethodIdentifier" />
        <Method name="equals" />
        <Bug pattern="NP_METHOD_PARAMETER_TIGHTENS_ANNOTATION" />
    </Match>

    <Match>
        <Class name="org.killbill.commons.utils.reflect.AbstractInvocationHandler" />
        <Method name="equals" />
        <Bug pattern="NP_METHOD_PARAMETER_TIGHTENS_ANNOTATION" />
    </Match>

    <!-- Verbatim copy from Guava ByteStreams.LimitedInputStream — mark/reset synchronization
         is identical to the original and acceptable for single-threaded stream usage. -->
    <Match>
        <Class name="org.killbill.commons.utils.io.ByteStreams$LimitedInputStream" />
        <Bug pattern="AT_NONATOMIC_64BIT_PRIMITIVE,AT_NONATOMIC_OPERATIONS_ON_SHARED_VARIABLE" />
    </Match>
</FindBugsFilter>
